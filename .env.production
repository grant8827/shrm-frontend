# API Configuration - Production
VITE_API_BASE_URL=https://safehaven-ehr-backend-nd-production.up.railway.app
VITE_WS_BASE_URL=wss://safehaven-ehr-backend-nd-production.up.railway.app
VITE_WEBRTC_FORCE_RELAY=false

# Optional dedicated TURN server (recommended for production reliability)
# VITE_TURN_URLS=turn:your-turn-host:3478?transport=udp,turn:your-turn-host:443?transport=tcp
# VITE_TURN_USERNAME=your-turn-username
# VITE_TURN_CREDENTIAL=your-turn-password

# Application Environment
VITE_APP_ENV=production
VITE_APP_NAME=SafeHaven EHR
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_DEBUG=false
VITE_ENABLE_AUDIT_LOGS=true

# PayPal Payments
# Get your live Client ID from https://developer.paypal.com/dashboard/applications/live
VITE_PAYPAL_CLIENT_ID=your-paypal-live-client-id-here

# HIPAA Compliance
VITE_SESSION_TIMEOUT=900000
VITE_AUTO_LOGOUT_WARNING=60000
